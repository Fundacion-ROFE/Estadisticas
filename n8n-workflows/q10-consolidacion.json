    },
    {
      "parameters": {
        "command": "={{ 'cd C:/Users/EstudiantesJC/Downloads/automatizaciones-empresa/scripts/q10-consolidacion && python q10_to_sheets.py --grupo ' + $json.grupo }}"
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [660, 160],
      "id": "a1b2c3d4-0001-0001-0001-000000000005",
      "name": "Ejecutar Script"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-exito-001",
              "leftValue": "={{ $json.exitCode }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 160],
      "id": "a1b2c3d4-0001-0001-0001-000000000006",
      "name": "Exito?"
    },
    {
      "parameters": {
        "chatId": "={{ $('Parsear Comando').first().json.chat_id }}",
        "text": "={{ (() => {\n  const stdout = $json.stdout || '';\n  const m = stdout.match(/RESUMEN: grupo=(\\S+) filas=(\\d+) estado=exito/);\n  const filas = m ? m[2] : '?';\n  const grupo = $('Parsear Comando').first().json.grupo.toUpperCase();\n  return '\\u2705 ' + grupo + ' actualizado\\u2014' + filas + ' filas cargadas.';\n})() }}",
        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1100, 60],
      "id": "a1b2c3d4-0001-0001-0001-000000000007",

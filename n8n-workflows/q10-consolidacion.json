    {
      "parameters": {
        "chatId": "={{ $('Parsear Comando').first().json.chat_id }}",
        "text": "={{ (() => {\n  const stdoutQ10 = $('Ejecutar q10_to_sheets').first().json.stdout || '';\n  const stdoutOrg = $('Ejecutar organizador').first().json.stdout || '';\n  const mQ10 = stdoutQ10.match(/RESUMEN: grupo=\\S+ filas=(\\d+) estado=exito/);\n  const mOrg = stdoutOrg.match(/RESUMEN: cursos=(\\d+) estudiantes=(\\d+) habilitados=(\\d+) promedio=([\\d.]+)/);\n  const filasQ10    = mQ10 ? mQ10[1] : '?';\n  const cursos      = mOrg ? mOrg[1] : '?';\n  const estudiantes = mOrg ? mOrg[2] : '?';\n  const habilitados = mOrg ? mOrg[3] : '?';\n  const promedio    = mOrg ? mOrg[4] : '?';\n  const statsOk  = $('Ejecutar export_stats').first().json.exitCode === 0;\n  const avanceOk = $json.exitCode === 0;\n  const ok = (v) => v ? '\\u2705' : '\\u26A0\\uFE0F';\n  return '\\u2705 Q10 actualizado\\n\\n' +\n    '\\ud83d\\udce5 Filas Q10: ' + filasQ10 + '\\n' +\n    '\\ud83d\\udcca Cursos: ' + cursos + ' | Activos: ' + habilitados + ' | Total: ' + estudiantes + ' | Prom: ' + promedio + '%\\n' +\n    ok(statsOk) + ' Stats \\u2192 GitHub Pages\\n' +\n    ok(avanceOk) + ' Avance \\u2192 GitHub Pages\\n' +\n    '\\n\\ud83c\\udf10 fundacion-rofe.github.io/Estadisticas/dashboard/';\n})() }}",

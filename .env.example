# ============================================================
# Panel de Datos ROFÉ — Supabase (proyecto: panel-datos-rofe)
# Copiar a .env.local y llenar los valores reales.
# .env.local NUNCA va a Git (verificar .gitignore).
# ============================================================

# URL del proyecto (pública, no es secreto)
SUPABASE_URL=https://kbxptoowtnteflhrfwid.supabase.co

# Anon key (pública por diseño — solo permite lo que RLS deja pasar:
# lectura de agregados y participantes con is_public=true)
SUPABASE_ANON_KEY=

# Publishable key moderna (alternativa recomendada al anon key para apps nuevas)
SUPABASE_PUBLISHABLE_KEY=

# Service role key — SECRETO. BYPASEA RLS. Solo para n8n / scripts de backend.
# Obtener en: Supabase Dashboard > Settings > API keys > service_role
# JAMÁS en frontend, JAMÁS en Git.
SUPABASE_SERVICE_ROLE_KEY=
# Q10 (plataforma académica) — usados por scripts/q10-consolidacion/q10_to_sheets.py
Q10_USUARIO=
Q10_PASSWORD=
